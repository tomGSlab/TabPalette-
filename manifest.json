{
  "manifest_version": 3,
  "name": "TabPaletté",
  "version": "1.0.1",
  "description": "Paint Your Digital Workspace.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open TabPaletté🎨"
  },
  "permissions": [
    "storage",
    "tabs",
    "favicon"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}